# BillSoft environment example
# Copy this file to .env for local development.
# Do not commit real environment values.

APP_ENV=Development
APP_BASE_URL=http://localhost:3010
VITE_BILLSOFT_API_BASE_URL=http://localhost:5000
API_BASE_URL=http://localhost:5000

# .NET configuration maps "__" to ":".
# SQL Server is the default and production provider.
Database__Provider=SqlServer
Database__ConnectionString=Server=localhost;Database=BillSoft;Trusted_Connection=True;TrustServerCertificate=True;
# Optional local-development/testing only:
# Database__Provider=Sqlite
# Database__ConnectionString=Data Source=billsoft.localdev.db;

Jwt__Issuer=BillSoft
Jwt__Audience=BillSoft
Jwt__SigningKey=replace-with-secure-secret
Jwt__AccessTokenLifetimeMinutes=15
Jwt__RefreshTokenLifetimeDays=7

BLOB_STORAGE_PROVIDER=AzureBlob
BLOB_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
BLOB_CONTAINER_VENDOR_BILLS=vendor-bills
BLOB_CONTAINER_EXPENSE_PROOFS=expense-proofs
BLOB_CONTAINER_REPORT_EXPORTS=report-exports

Ocr__Provider=Fake
Ocr__MaxUploadBytes=10485760
Ocr__StorageRootPath=./App_Data/vendor-bill-ocr
Ocr__AzureDocumentIntelligence__Endpoint=
Ocr__AzureDocumentIntelligence__ApiKey=
Ocr__AzureDocumentIntelligence__ModelId=prebuilt-invoice

REPORT_MORNING_TIME=11:30
REPORT_AFTERNOON_TIME=16:00
REPORT_CLOSING_TIME=22:30

DEFAULT_TIMEZONE=Asia/Singapore
DEFAULT_CURRENCY=SGD
