{
  "name": "billsoft-web",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.3",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && pnpm run verify:swa-config",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile.junit=test-results/vitest-junit.xml",
    "verify:swa-config": "node scripts/verify-swa-config.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "6.30.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "27.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "3.2.6"
  }
}
